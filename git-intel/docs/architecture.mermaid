---
title: Git Intel вҖ” Component Architecture
---
graph TD
    CFG["рҹ“„ config.json\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nopenai_api_key\nmodel\nrepositories\nschedule_minutes\nlookback_commits\ndashboard_port"]

    subgraph PYTHON ["Python Backend  (git-intel/)"]
        MAIN["рҹҡҖ main.py\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nload_config()\nrun_once()\nscheduler loop"]
        GP["рҹ”Қ git_parser.py\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nget_commits()\nget_file_tree()"]
        LC["рҹӨ– llm_client.py\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nbuild_prompt()\nsummarise()\n_extract_usage()"]
        LW["рҹ’ҫ log_writer.py\nв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ\nappend_entry()\nwrite_file_tree()\nappend_token_log()\nwrite_index()\nget_token_summary()"]
    end

    subgraph STORE ["store/  (JSON files on disk)"]
        SL["рҹ“Ҡ &lt;repo&gt;.json\nChange log entries\n+ token_usage per entry"]
        ST["рҹҢі &lt;repo&gt;-tree.json\nFile tree snapshot"]
        STK["рҹӘҷ token_usage.json\nAll API call records\nwith timestamps"]
        SI["рҹ“Ӣ index.json\nRepo name manifest"]
    end

    subgraph EXTERNAL ["External Services"]
        OAI["вҳҒпёҸ OpenAI API\nchat.completions.create"]
    end

    subgraph DASHBOARD ["Dashboard  (dashboard/)"]
        HTTP["рҹҢҗ Python http.server\nServes /store/ + /dashboard/"]
        HTML["index.html\nPage shell"]
        JS["app.js\nFetch + render"]
        CSS["style.css\nLight / dark theme"]
        DIAG["diagrams.html\nArchitecture viewer"]
    end

    GIT["рҹ—ӮпёҸ Git Repositories\n(local, on disk)"]

    %% Config flows into main
    CFG --> MAIN

    %% Main orchestrates everything
    MAIN -->|"get_commits(path, last_sha, lookback)"| GP
    MAIN -->|"get_file_tree(path)"| GP
    GP -->|"commit dicts list"| MAIN
    GP -->|"nested tree dict"| MAIN
    GP -->|"iter_commits()"| GIT

    MAIN -->|"summarise(api_key, model, commits)"| LC
    LC -->|"chat.completions.create(...)"| OAI
    OAI -->|"choices[0].message\n+ usage.{prompt,completion,total}_tokens"| LC
    LC -->|"(summary_str, token_usage_dict)"| MAIN

    MAIN -->|"append_entry(name, entry)"| LW
    MAIN -->|"write_file_tree(name, tree)"| LW
    MAIN -->|"append_token_log(name, model, tokens)"| LW
    MAIN -->|"write_index(repo_names)"| LW

    LW --> SL
    LW --> ST
    LW --> STK
    LW --> SI

    %% Dashboard reads from store
    SL --> HTTP
    ST --> HTTP
    STK --> HTTP
    SI --> HTTP
    HTTP --> JS
    JS -->|"fetch /store/index.json"| SI
    JS -->|"fetch /store/&lt;repo&gt;.json"| SL
    JS -->|"fetch /store/&lt;repo&gt;-tree.json"| ST
    HTML --- JS
    HTML --- CSS
    HTML --- DIAG

    classDef config  fill:#fff9e6,stroke:#d4a017,color:#333
    classDef python  fill:#dbeafe,stroke:#3b82f6,color:#1e3a5f
    classDef store   fill:#dcfce7,stroke:#16a34a,color:#14532d
    classDef ext     fill:#fce7f3,stroke:#db2777,color:#831843
    classDef dash    fill:#f3e8ff,stroke:#9333ea,color:#3b0764
    classDef git     fill:#fef3c7,stroke:#d97706,color:#78350f

    class CFG config
    class MAIN,GP,LC,LW python
    class SL,ST,STK,SI store
    class OAI ext
    class HTTP,HTML,JS,CSS,DIAG dash
    class GIT git
